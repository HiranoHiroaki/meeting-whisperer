    },
    {
      "at_ms": 63800,
      "type": "line",
      "index": 30,
      "speaker": "西田",
      "text": "あと医療、\n同じ略語でも診療科で意味変わることありますよね。",
      "highlight_terms": []
    },
    {
      "at_ms": 66000,
      "type": "line",
      "index": 31,
      "speaker": "岡本",
      "text": "あります。\nPTとか典型。",
      "highlight_terms": [
        "PT"
      ]
