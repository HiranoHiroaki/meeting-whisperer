      "at_ms": 66450,
      "type": "term_chip",
      "terms": [
        "PT"
      ]
    },
    {
      "at_ms": 68200,
      "type": "line",
      "index": 32,
      "speaker": "加藤",
      "text": "理学療法なのかプロトロンビン時間なのか。",
      "highlight_terms": []
    },
    {
      "at_ms": 70400,
      "type": "line",
      "index": 33,
      "speaker": "岡本",
      "text": "そこかなり危険。",
      "highlight_terms": []
    },
    {
      "at_ms": 72600,
      "type": "line",
      "index": 34,
      "speaker": "加藤",
      "text": "「この人理解不足です」\nみたいに感じると終わる。",
      "highlight_terms": []
    },
    {
      "at_ms": 74800,
      "type": "line",
      "index": 35,
      "speaker": "森",
      "text": "完全に補助限定。",
      "highlight_terms": []
    },
    {
      "at_ms": 77000,
      "type": "line",
      "index": 36,
      "speaker": "西田",
      "text": "「最近確認した概念」\nくらいが限界かな。",
      "highlight_terms": []
    },
    {
      "at_ms": 79200,
      "type": "line",
      "index": 37,
      "speaker": "森",
      "text": "それ正解だと思います。",
      "highlight_terms": []
    },
    {
      "at_ms": 81400,
      "type": "line",
      "index": 38,
      "speaker": "岡本",
      "text": "ナースステーション常に音鳴ってるし。",
      "highlight_terms": []
    },
    {
      "at_ms": 83600,
      "type": "line",
      "index": 39,
      "speaker": "森",
      "text": "それだけでも十分価値あると思う。",
      "highlight_terms": []
    },
