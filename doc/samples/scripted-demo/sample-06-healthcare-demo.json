    {
      "at_ms": 33000,
      "type": "line",
      "index": 16,
      "speaker": "加藤",
      "text": "そこかなり慎重にいきたいですね…。",
      "highlight_terms": []
    },
    {
      "at_ms": 35200,
      "type": "line",
      "index": 17,
      "speaker": "西田",
      "text": "あと退院調整、\nMSW側まだ動けてないみたいです。",
